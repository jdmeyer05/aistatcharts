# Never ship these into the image.
.git
.github
.vscode
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache
.mypy_cache
.ruff_cache

# Secrets / local-only state
.env
.env.*
.streamlit/secrets.toml
supabase_schema.sql
supabase_schema.txt
supabase_trump_decoder.sql
supabase_rls_migration.sql

# The Next.js frontend is deployed on Vercel — don't ship any of it in the
# FastAPI container. Keeping `frontend/` out also prevents frontend edits from
# invalidating the Docker build cache.
frontend/

# NOTE: app.py + pages/ intentionally NOT excluded — the combined
# Streamlit+FastAPI image (main Dockerfile) needs them at runtime. Their
# cost in the FastAPI-only image is under 1 MB, which is not worth the
# fragility of maintaining two separate ignore lists per Dockerfile.

# Local caches, dev artifacts
data/gdelt_events/*.json
data/*.sqlite
data/*.db
*.log
logs/
.DS_Store

# Misc working files
MARKETING_PLAN.md
TWEET_TEMPLATES.txt
PROMPT_HISTORY.txt
UX_IMPROVEMENTS_CHANGELOG.txt
SECTOR_EXPANSION_PLAN.md
rh_debug.py
rh_login.py
